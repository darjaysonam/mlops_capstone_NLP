name: MultiLabelNLP

python_env: python_env.yaml

entry_points:
  main:
    parameters:
      epochs: {type: int, default: 10}
      lr: {type: float, default: 0.001}
      batch_size: {type: int, default: 32}
    command: >
      python training.py
      --epochs {epochs}
      --lr {lr}
      --batch_size {batch_size}